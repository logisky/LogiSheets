{
    "name": "logisheets-engine",
    "author": "Jeremy He<yiliang.he@qq.com>",
    "license": "MIT",
    "version": "1.7.0",
    "description": "LogiSheets spreadsheet engine - a high-performance spreadsheet rendering and editing library",
    "type": "module",
    "main": "./dist/logisheets-engine.umd.js",
    "module": "./dist/logisheets-engine.es.js",
    "types": "./dist/types/lib/global.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/lib/global.d.ts",
            "import": "./dist/logisheets-engine.es.js",
            "require": "./dist/logisheets-engine.umd.js"
        },
        "./style.css": "./dist/logisheets-engine.css"
    },
    "scripts": {
        "dev": "vite dev",
        "build": "vite build --config vite.config.lib.ts && yarn build:types",
        "build:types": "svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.types.json",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "preview": "vite preview",
        "prepack": "yarn build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/logisky/LogiSheets.git"
    },
    "keywords": [
        "spreadsheet",
        "excel",
        "xlsx",
        "canvas",
        "webworker"
    ],
    "files": [
        "dist"
    ],
    "dependencies": {
        "logisheets-web": "^1.7.0",
        "rxjs": "^7.8.1",
        "ssf": "^0.11.2"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^4.0.0",
        "@tsconfig/svelte": "^5.0.4",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "terser": "^5.46.0",
        "typescript": "^5.5.0",
        "vite": "^6.0.0"
    },
    "bugs": {
        "url": "https://github.com/logisky/LogiSheets/issues"
    },
    "homepage": "https://github.com/logisky/LogiSheets"
}
