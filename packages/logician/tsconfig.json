{
    "compilerOptions": {
        "target": "ES2018",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "rootDir": "src",
        "declarationDir": "dist",
        "outDir": "dist",
        "isolatedModules": true,
        "lib": ["ES2018", "DOM"]
    },
    "include": ["src"]
}
