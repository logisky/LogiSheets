{
    "compilerOptions": {
        "allowJs": true,
        "declaration": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noImplicitAny": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": ".",
        "outDir": "./dist/",
        "target": "ESNext"
    },
    "files": [
        "index.ts"
