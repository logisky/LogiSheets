{
    "name": "factory-simulator-en",
    "version": "0.1.0",
    "description": "Run your factory! (English edition)",
    "main": "dist/factory-simulator.js",
    "module": "dist/factory-simulator.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "vite build && yarn copy-to-public",
        "copy-to-public": "rm -rf ../../public/factory-simulator-en && mkdir -p ../../public/factory-simulator-en && cp index.html ../../public/factory-simulator-en/index.html && cp dist/factory-simulator.js ../../public/factory-simulator-en/factory-simulator.js",
        "test": "vitest run"
    },
    "keywords": [
        "factory",
        "management",
        "game"
    ],
    "author": "Jeremy He",
    "license": "MIT",
    "dependencies": {
        "factory-simulator-core": "workspace:*",
        "logisheets-web": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.5.0",
        "vite": "^5.0.0"
    }
}
