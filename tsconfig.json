{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "types": ["reflect-metadata", "vitest/globals", "node"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "noFallthroughCasesInSwitch": true,
    "outDir": "./dist/",
    "paths": {
      "@/*": ["./src/*"],
      "logisheets-formula-editor": ["./packages/formula-editor/src/lib/index.ts"],
      "logisheets-formula-editor/inline": [
        "./packages/formula-editor/src/lib/inline.ts"
      ],
      "logisheets-zk-web": ["./packages/zk-web/src/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ESNext"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
      "moduleResolution": "node16"
    }
  },
  "include": [
    "src/**/*.tsx",
    "src/**/*.ts",
    "packages/web/**/*.ts",
    "packages/formula-editor/src/**/*.ts",
    "packages/formula-editor/src/**/*.tsx",
    "packages/zk-web/src/**/*.ts"
  ]
}
