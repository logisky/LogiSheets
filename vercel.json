{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "buildCommand": null,
    "installCommand": null,
    "outputDirectory": "dist",
    "trailingSlash": false,
    "headers": [
        {
            "source": "/(.*)\\.wasm",
            "headers": [
                { "key": "Content-Type", "value": "application/wasm" },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}
