INPUT A2 Vegetables
INPUT A3 Vegetables
INPUT A4 Fruits
INPUT A6 Vegetables
INPUT A7 Fruits

INPUT B2 Tomatoes
INPUT B3 Celery
INPUT B4 Oranges
INPUT B5 Butter
INPUT B6 Carrots
INPUT B7 Apples

INPUT C2 2300
INPUT C3 5500
INPUT C4 800
INPUT C5 400
INPUT C6 4200
INPUT C7 1200

INPUT A1 =SUMIF(A2:A7,"Fruits",C2:C7)
CHECKNUM A1 2000
INPUT E1 =SUMIF(A2:A7,"Vegetables",C2:C7)
CHECKNUM E1 12000

# wildcard criteria on the label column
INPUT E2 =SUMIF(A2:A7,"F*",C2:C7)
CHECKNUM E2 2000

# numeric comparison criteria over a standalone column
INPUT F1 100
INPUT F2 200
INPUT F3 300
INPUT F4 400
INPUT E3 =SUMIF(F1:F4,">150")
CHECKNUM E3 900
INPUT E4 =SUMIF(F1:F4,">=300")
CHECKNUM E4 700
INPUT E5 =SUMIF(F1:F4,"<>200")
CHECKNUM E5 800