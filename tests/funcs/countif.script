INPUT   A1  =2
INPUT   A2  =2
INPUT C10    =COUNTIF(A1:A2,0)
CHECKNUM C10 0

INPUT D1 5
INPUT D2 10
INPUT D3 15
INPUT D4 20
INPUT D5 apple
INPUT D6 apricot
INPUT D7 banana

# numeric comparison operators
INPUT C1 =COUNTIF(D1:D4,">10")
CHECKNUM C1 2
INPUT C2 =COUNTIF(D1:D4,">=10")
CHECKNUM C2 3
INPUT C3 =COUNTIF(D1:D4,"<>10")
CHECKNUM C3 3

# wildcard text match
INPUT C4 =COUNTIF(D5:D7,"a*")
CHECKNUM C4 2
INPUT C5 =COUNTIF(D5:D7,"*an*")
CHECKNUM C5 1