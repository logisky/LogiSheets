INPUT A1 3
INPUT A2 1
INPUT A3 4
INPUT A4 1
INPUT A5 5

# k-th largest (with duplicates)
INPUT C1 =LARGE(A1:A5,1)
CHECKNUM C1 5
INPUT C2 =LARGE(A1:A5,2)
CHECKNUM C2 4
INPUT C3 =LARGE(A1:A5,3)
CHECKNUM C3 3
INPUT C4 =LARGE(A1:A5,4)
CHECKNUM C4 1

# k < 1 -> #NUM!
INPUT C5 =LARGE(A1:A5,0)
CHECKERR C5 #NUM!

# k greater than the number of values -> #NUM!
INPUT C6 =LARGE(A1:A5,6)
CHECKERR C6 #NUM!
