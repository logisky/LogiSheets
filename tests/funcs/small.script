INPUT A1 3
INPUT A2 1
INPUT A3 4
INPUT A4 1
INPUT A5 5

# k-th smallest (with duplicates)
INPUT C1 =SMALL(A1:A5,1)
CHECKNUM C1 1
INPUT C2 =SMALL(A1:A5,2)
CHECKNUM C2 1
INPUT C3 =SMALL(A1:A5,3)
CHECKNUM C3 3
INPUT C4 =SMALL(A1:A5,5)
CHECKNUM C4 5

# k < 1 -> #NUM!
INPUT C5 =SMALL(A1:A5,0)
CHECKERR C5 #NUM!

# k greater than the number of values -> #NUM!
INPUT C6 =SMALL(A1:A5,6)
CHECKERR C6 #NUM!
