INPUT A2 1st
CHECKSTR A2 1st
INPUT A3 2nd
CHECKSTR A3 2nd
INPUT A4 3rd
CHECKSTR A4 3rd
INPUT A5 Finished
CHECKSTR A5 Finished

INPUT B2 Nails
CHECKSTR B2 Nails
INPUT B3 Screws
CHECKSTR B3 Screws
INPUT B4 Nuts
CHECKSTR B4 Nuts
INPUT B5 Bolts
CHECKSTR B5 Bolts

INPUT E1 =CHOOSE(2,A2,A3,A4,A5)
CHECKSTR E1 2nd

INPUT E2 =CHOOSE(4,B2,B3,B4,B5)
CHECKSTR E2 Bolts

INPUT E3 =CHOOSE(3,"Wide",115,"world",8)
CHECKSTR E3 world

# index is truncated toward zero
INPUT E4 =CHOOSE(2.9,10,20,30)
CHECKNUM E4 20

# index beyond the value list -> #VALUE!
INPUT E5 =CHOOSE(4,10,20,30)
CHECKERR E5 #VALUE!

# index < 1 -> #VALUE!
INPUT E6 =CHOOSE(0,10,20,30)
CHECKERR E6 #VALUE!
INPUT E7 =CHOOSE(-1,10,20,30)
CHECKERR E7 #VALUE!