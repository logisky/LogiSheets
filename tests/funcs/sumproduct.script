INPUT A1 1
INPUT A2 2
INPUT A3 3
INPUT B1 4
INPUT B2 5
INPUT B3 6
# 1*4 + 2*5 + 3*6 = 32
INPUT C1 =SUMPRODUCT(A1:A3, B1:B3)
CHECKNUM C1 32
# a single array is just its sum
INPUT C2 =SUMPRODUCT(A1:A3)
CHECKNUM C2 6
# mismatched dimensions -> #VALUE!
INPUT C3 =SUMPRODUCT(A1:A3, B1:B2)
CHECKERR C3 #VALUE!
