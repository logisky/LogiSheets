INPUT A1 =ROUND(0.79, 1)
CHECKNUM A1 0.8

INPUT A2 =ROUND(0.791, 2)
CHECKNUM A2 0.79

INPUT A3 =ROUND(0.79, 0)
CHECKNUM A3 1

INPUT A4 =ROUND(0.79, -1)
CHECKNUM A4 0

INPUT A5 =ROUND(12.79, -1)
CHECKNUM A5 10

INPUT A6 =ROUND(-12.79, -1)
CHECKNUM A6 -10

# ties round half away from zero
INPUT A7 =ROUND(0.5, 0)
CHECKNUM A7 1

INPUT A8 =ROUND(1.5, 0)
CHECKNUM A8 2

INPUT A9 =ROUND(2.5, 0)
CHECKNUM A9 3

INPUT A10 =ROUND(-2.5, 0)
CHECKNUM A10 -3

INPUT A11 =ROUND(2.25, 1)
CHECKNUM A11 2.3
