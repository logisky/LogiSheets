INPUT A1 =ADDRESS(1,1)
CHECKSTR A1 $A$1
INPUT A2 =ADDRESS(2,3)
CHECKSTR A2 $C$2
# abs_num 4 -> relative
INPUT A3 =ADDRESS(2,3,4)
CHECKSTR A3 C2
# abs_num 2 -> absolute row only
INPUT A4 =ADDRESS(2,3,2)
CHECKSTR A4 C$2
# R1C1 style
INPUT A5 =ADDRESS(1,1,1,FALSE)
CHECKSTR A5 R1C1
# with sheet prefix
INPUT A6 =ADDRESS(2,3,1,TRUE,"Sheet1")
CHECKSTR A6 Sheet1!$C$2
